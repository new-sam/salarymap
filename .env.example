# FYI 환경변수 템플릿
# 실제 값은 여기에 적지 말 것 — .env.local 에 채우고, 값은 안전한 채널(1Password 등)로만 공유.
# 코드에서 실제 사용 중인 키 전부를 정리한 것.

# ──────────────────────────────────────────────
# Supabase (앱 기본 — 없으면 아무것도 안 됨)
# Supabase 대시보드 → Project Settings → API
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=          # Project URL (예: https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # anon public key (클라 노출 OK)
SUPABASE_SERVICE_ROLE_KEY=         # service_role key — 서버 전용, 절대 클라/깃 노출 금지

# ──────────────────────────────────────────────
# Resend (메일 발송 — 합·반려·면접·초대 메일)  ★ 메일만 쓰려면 이 두 개만 있으면 됨
# resend.com → API Keys
# ──────────────────────────────────────────────
RESEND_API_KEY=                    # re_... 형식. 없으면 메일 API가 503 반환
RESEND_FROM=                       # 검증된 발신 주소. 미설정 시 기본값 'FYI <onboarding@resend.dev>' 사용
                                   #   ※ 실제 도메인 발송하려면 Resend에서 도메인 인증(DKIM) 필요

# ──────────────────────────────────────────────
# Google OAuth (기업 로그인)
# Google Cloud Console → APIs & Services → Credentials
# 승인된 redirect URI: {사이트URL}/api/auth/google/callback
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────
# 알림 / 기타 (대부분 선택)
# ──────────────────────────────────────────────
SLACK_WEBHOOK_URL=                 # (선택) 새 공고 승인대기 등 어드민 Slack 알림
CONTACT_NOTIFY_EMAIL=              # (선택) 어드민 알림 수신 메일. 미설정 시 ceo_office@likelion.net
CRON_SECRET=                       # 크론 엔드포인트 인증 토큰
UNSPLASH_ACCESS_KEY=               # (선택) 이미지 가져오기
NEXT_PUBLIC_SITE_URL=              # 사이트 절대 URL (예: https://salary-fyi.com)
# NODE_ENV 는 런타임이 자동 설정 — 직접 넣지 않음
